# Copy to .env and fill in. Get your key at https://console.runpod.io/user/settings
RUNPOD_API_KEY=

# Bright Data SERP API — live multi-supplier pricing (pricing/ + scripts/check_brightdata.py).
# Create a SERP API zone at https://brightdata.com (Web Access API -> SERP API).
BRIGHTDATA_API_KEY=
# Your SERP zone name (defaults to "serp_api" if unset).
BRIGHTDATA_SERP_ZONE=serp_api1
