# Copy to .env and fill in your values.

# Runpod Flash API key (same key used by the Flash CLI / takeoff_worker.py)
RUNPOD_API_KEY=your_runpod_api_key_here

# Flash endpoint URL.
# Default points at the `flash dev` local server (no key needed for local dev).
# For a deployed endpoint replace with the Runpod endpoint URL.
RUNPOD_ENDPOINT_URL=http://localhost:8888/takeoff_worker/runsync

# Seconds to wait for the Runpod worker (cold start can take ~30-60 s).
RUNPOD_TIMEOUT=120

# SQLite database file path (relative to where uvicorn is launched).
DATABASE_URL=sqlite:///./flashpod.db

# Directory for uploaded drawings and template crops.
UPLOAD_DIR=uploads
