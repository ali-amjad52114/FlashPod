# Copy to .env and fill in your values.

# Runpod Flash API key (same key used by the Flash CLI / takeoff_worker.py)
RUNPOD_API_KEY=your_runpod_api_key_here

# Flash endpoint URL.
# Default points at the `flash dev` local server (no key needed for local dev).
# For a deployed endpoint replace with the Runpod endpoint URL.
RUNPOD_ENDPOINT_URL=http://localhost:8888/takeoff_worker/runsync

# Seconds to wait for the Runpod worker (cold start can take ~30-60 s).
RUNPOD_TIMEOUT=120

# --- Bright Data live-pricing service (teammate-owned) ---
# URL of the pricing service that returns live material unit prices per symbol type.
# Leave UNSET to disable live pricing — the backend then keeps the worker's
# built-in fallback prices, so everything still works before the service is wired in.
BRIGHTDATA_PRICING_URL=
# API key for the pricing service (sent as `Authorization: Bearer ...` if set).
BRIGHTDATA_API_KEY=
# Seconds to wait for the pricing service before falling back.
BRIGHTDATA_TIMEOUT=20

# SQLite database file path (relative to where uvicorn is launched).
DATABASE_URL=sqlite:///./flashpod.db

# Directory for uploaded drawings and template crops.
UPLOAD_DIR=uploads
